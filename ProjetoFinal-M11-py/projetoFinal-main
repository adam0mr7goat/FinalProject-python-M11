# sends an email to the candidate with their status
def send_email(candidate):
    sender = "candidaturacursos@gmail.com"
    password = "szqnknemhrfweani"
    
    subject = "Course Registration - " + candidate["status"]
    body = "Hello " + candidate["name"] + ",\n\nYour registration status is: " + candidate["status"] + "\n\nCourse: " + candidate["course"] + "\n\nThank you!"
    
    msg = MIMEText(body)
    msg["Subject"] = subject
    msg["From"] = sender
    msg["To"] = candidate["email"]
    
    try:
        server = smtplib.SMTP_SSL("smtp.gmail.com", 465)
        server.login(sender, password)
        server.sendmail(sender, candidate["email"], msg.as_string())
        server.quit()
        print("Email sent to " + candidate["email"])
    except:
        print("Failed to send email.")

# ---------------------------------------
# loads all candidates from the file and displays each one
def list_candidates():
    candidates = load_candidates()
    if len(candidates) == 0: # if the list is empty print ... if not show the list :)
        print("No candidates registered.")
    else:
        for c in candidates:
            print("Name: " + c["name"])
            print("Age: " + str(c["age"]))
            print("Status: " + c["status"])
# ---------------------------------------
def search_candidate():
    search = input("Enter name to search: ")
    candidates = load_candidates()
    found = False
    for c in candidates:
        if c["name"].lower() == search.lower(): # so this lower do , it change it to a lower case before it convert it make it , like if i ask for a name and the if say if name = Adam --- but you wirte ADAM , it will still undersand it 
            print("Name: " + c["name"])
            print("Age: " + str(c["age"]))
            print("Email: " + c["email"])
            print("Status: " + c["status"])
            found = True
    if not found:
        print("Candidate not found.")

# ---------------------------------------
# export accepted and rejected candidates to separate files
def export_candidates():
    candidates = load_candidates()
    
    accepted = []
    rejected = []
    
    for c in candidates:
        if c["status"] == "Accepted":
            accepted.append(c)
        else:
            rejected.append(c)
    
    with open("accepted.json", "w") as f:
        json.dump(accepted, f, indent=4)
    
    with open("rejected.json", "w") as f:
        json.dump(rejected, f, indent=4)
    
    print("Exported successfully!")
    print("Accepted candidates: " + str(len(accepted)))
    print("Rejected candidates: " + str(len(rejected)))

