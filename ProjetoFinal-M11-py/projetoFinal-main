import json
import os
from fpdf import FPDF # to creat a PDF and put the info there
import smtplib
from email.mime.text import MIMEText

FILE = "candidates.json" 

def load_candidates(): 
    if os.path.exists(FILE): # see if the file even exist :) 
        with open(FILE,"r") as f : 
            return json.load(f)
    return [] # return an empty list 

def save_candidates(candidates):
    with open(FILE, "w") as f:
        json.dump(candidates, f, indent=4)

def register_candidate(): 
    name = input("Full name: ")
    age = int(input("Age: "))
    email = input("Your email: ")
    education = input("Education level (basic/secondary): ")
    course = input("Desired course: ")
    mathGrade = float(input("Math grade: "))
    ptGrade = float(input("Portuguese grade: "))
    failures = int(input("Number of failures in 9th grade: "))

    candidate = {
        "name": name,
        "age": age,
        "email": email,
        "education": education,
        "course": course,
        "mathGrade": mathGrade,
        "ptGrade": ptGrade,
        "failures": failures,
        "status": ""
    }
    candidate = evaluate_candidate(candidate)
    # here we evaluate the candidate after we collect all the info and put them in the dictionary
    # so the function can check their age and education level
    # and set their status to accepted or rejected before saving to the file

    candidates = load_candidates()
    candidates.append(candidate)
    save_candidates(candidates)
    generate_pdf(candidate)
    send_email(candidate)
    print("Candidate registered successfully!")

# ---------------------------------------
def evaluate_candidate(candidate):
    if 15 <= candidate["age"] <= 18 and candidate["education"] == "basic":
        candidate["status"] = "Accepted"
    else:
        candidate["status"] = "Rejected"
    return candidate

# ---------------------------------------
# generates a PDF receipt for the candidate
def generate_pdf(candidate):
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Arial", size=12)
    
    pdf.set_font("Arial", "B", 16)
    pdf.cell(200, 10, txt="COURSE REGISTRATION RECEIPT", ln=True, align="C")
    pdf.ln(10)
    pdf.set_font("Arial", size=12)
    pdf.cell(200, 10, txt="Name: " + candidate["name"], ln=True)
    pdf.cell(200, 10, txt="Age: " + str(candidate["age"]), ln=True)
    pdf.cell(200, 10, txt="Email: " + candidate["email"], ln=True)
    pdf.cell(200, 10, txt="Course: " + candidate["course"], ln=True)
    pdf.cell(200, 10, txt="Status: " + candidate["status"], ln=True)
    
    filename = candidate["name"] + "_receipt.pdf"
    pdf.output(filename)
    print("PDF generated: " + filename)

